# ─────────────────────────────────────────────────────────────────────────────
#  Ekta Digital — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the .env file to Git.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME="Ekta Digital"
APP_ENV=production
APP_KEY=                         # php artisan key:generate
APP_DEBUG=false
APP_URL=                         # e.g. https://ekta-backend.up.railway.app
APP_TIMEZONE=Africa/Dar_es_Salaam

LOG_CHANNEL=stack
LOG_LEVEL=error

# ─── Database ─────────────────────────────────────────────────────────────────
# For Supabase: copy the "Connection string" from Project Settings → Database → URI
# It looks like: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DB_CONNECTION=pgsql
DB_HOST=                         # Supabase pooler host
DB_PORT=6543                     # 6543 for transaction mode (recommended for Railway)
DB_DATABASE=postgres
DB_USERNAME=postgres             # or postgres.[project-ref]
DB_PASSWORD=                     # Supabase database password
DB_SSLMODE=require               # Required for Supabase

# ─── Cache / Session / Queue ──────────────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=sync

# ─── Mail ─────────────────────────────────────────────────────────────────────
# Brevo (free 300 emails/day) — https://brevo.com
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=                   # Your Brevo SMTP login (email address)
MAIL_PASSWORD=                   # Your Brevo SMTP key
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=EktaDigital@outlook.com
MAIL_FROM_NAME="Ekta Digital"

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Free tier: 25GB storage, 25GB bandwidth/month — https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=                  # cloudinary://api_key:api_secret@cloud_name

# ─── Frontend URL (for CORS and password reset links) ─────────────────────────
# Comma-separate multiple URLs if needed: https://ekta.vercel.app,https://ektadigital.co.tz
FRONTEND_URL=                    # e.g. https://ekta-digital.vercel.app

# ─── Sanctum ──────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=        # e.g. ekta-digital.vercel.app (no https://)

# ─── WhatsApp Notifications (Callmebot) ───────────────────────────────────────
WHATSAPP_NUMBER=255783394445
WHATSAPP_API_KEY=

# ─── Payment Gateways ─────────────────────────────────────────────────────────

# Selcom — Tanzania (M-Pesa, Airtel, CRDB, Selcom Wallet, Visa, Mastercard)
# Register at: https://developer.selcommobile.com
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_VENDOR_ID=
SELCOM_BASE_URL=https://apigw.selcommobile.com/v1

# PayPal — International
# Create app at: https://developer.paypal.com/developer/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=live                 # sandbox | live
PAYPAL_TZS_TO_USD_RATE=0.00038  # Update regularly

# Bank Transfer — B2B
BANK_ACCOUNT_NUMBER=
BANK_ACCOUNT_NAME=Ekta Digital Ltd
BANK_NAME=CRDB Bank
BANK_BRANCH=India Street, Dar-es-Salaam
BANK_SWIFT=CORUTZTZ
